config BOARD_HEXIWEAR_MK64F12
	bool
	select SOC_MK64F12

config BOARD_HEXIWEAR_MKW40Z4
	bool
	select SOC_MKW40Z4

config SOC_PART_NUMBER
	default "MK64FN1M0VDC12" if BOARD_HEXIWEAR_MK64F12
	default "MKW40Z160VHT4" if BOARD_HEXIWEAR_MKW40Z4
